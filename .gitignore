# Emacs desktop file — saved session state
/.emacs.desktop
# Lock file preventing two Emacs instances from loading session
/.emacs.desktop.lock
# Compiled Emacs Lisp bytecode
*.elc
# Emacs list of auto-save files
auto-save-list
# Emacs Tramp remote-connection state
tramp
# Emacs lock symlinks (created while editing a file)
.\#*

# --- Sublime Text ---

# Sublime compiled syntax grammar cache
*.tmlanguage.cache
# Sublime compiled preferences cache
*.tmPreferences.cache
# Sublime compiled theme cache
*.stTheme.cache
# Sublime workspace — open files, pane layout (machine-specific)
*.sublime-workspace
# Sublime project file (may contain absolute paths)
*.sublime-project
# Sublime SFTP plugin config — may contain credentials!
sftp-config.json
# Sublime Package Control metadata
Package Control.last-run
Package Control.ca-list
Package Control.ca-bundle
Package Control.system-ca-bundle

# --- Atom ---

# Atom editor settings and packages directory
.atom/

# --- TextMate ---

# TextMate project file
*.tmproj
*.tmproject
# TextMate tags file
tmtags

# --- Notepad++ ---

# Notepad++ backup files directory
nppBackup/

# --- Xcode ---

# Per-developer breakpoints, scheme, and window state
*.xcodeproj/xcuserdata/
# Same, for workspaces
*.xcworkspace/xcuserdata/
# Xcode canvas preview snapshots
*.xcworkspace/xcshareddata/previews/
# Files renamed by Xcode during a framework migration
*.moved-aside
# Old Xcode per-user project settings
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
# Xcode build products and intermediate files (large, auto-rebuilt)
DerivedData/
# Xcode header map (auto-generated C/C++ include index)
*.hmap
# Compiled iOS application archive (build artifact)
*.ipa
# Xcode archive (build artifact, often hundreds of MB)
*.xcarchive


# =============================================================================
# SECTION 3 — DEPENDENCY DIRECTORIES
# Package managers download and install dependencies on demand from a lockfile.
# Committing these directories bloats the repo (often hundreds of MB), creates
# OS-specific binary conflicts, and gives a false sense of reproducibility.
# =============================================================================

# --- JavaScript / Node.js ---

# npm/yarn/pnpm installed packages — restored via package-lock.json
node_modules/
# npm error log — per-run diagnostics, not project state
npm-debug.log*
# Yarn debug log
yarn-debug.log*
# Yarn error log
yarn-error.log*
# pnpm debug log
.pnpm-debug.log*
# npm cache directory
.npm/
# Yarn Berry (v2+) download cache (commit only if using Zero-Installs)
.yarn/cache
# Yarn Berry unpacked native modules
.yarn/unplugged
# Yarn Berry build state
.yarn/build-state.yml
# Yarn Plug'n'Play loader (commit only if using PnP)
.pnp.js
.pnp.cjs

# --- Python ---

# Python 3 bytecode cache directory
