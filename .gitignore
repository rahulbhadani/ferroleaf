# =============================================================================
# SECTION 4 — BUILD TOOLS & TASK RUNNERS
# Build outputs are always regenerated — committing them causes multi-MB diffs
# on trivial code changes and prevents reproducible builds from source.
# =============================================================================

# --- webpack ---
.cache/                    # webpack persistent cache (speeds up rebuilds, not project data)
dist/                      # webpack bundle output — rebuilt on deploy
.parcel-cache/             # Parcel bundler cache

# --- Vite ---
dist/                      # Vite production build output
.vite/                     # Vite dev server cache

# --- Rollup ---
.rollup.cache/             # Rollup build cache

# --- Grunt / Gulp ---
.grunt/                    # Grunt plugin cache
.sass-cache/               # Sass/SCSS compiled cache (used by many task runners)

# --- Bower ---
bower_components/          # Bower installed front-end packages (deprecated, use npm)

# --- Bazel ---
bazel-*                    # Bazel symlinked output directories (bazel-bin, bazel-out, etc.)
/bazel-out                 # Bazel output directory

# --- Buck ---
buck-out/                  # Buck build output directory

# --- Make ---
*.d                        # GCC auto-generated dependency files for incremental builds


# =============================================================================
# SECTION 5 — TEST & COVERAGE OUTPUTS
# Test results and coverage reports are generated by CI — committing them makes
# the repo reflect the last local run rather than the canonical CI state.
# =============================================================================

coverage/                  # Code coverage report directory (JavaScript/generic)
*.lcov                     # LCOV coverage data file
.nyc_output/               # Istanbul/nyc raw coverage data (JavaScript)
htmlcov/                   # Python coverage.py HTML report
.coverage                  # Python coverage.py binary data file
.coverage.*                # Python coverage.py combined data
coverage.xml               # Python/generic XML coverage report (e.g., for Codecov)
nosetests.xml              # Nose test results XML
pytest-report.html         # Pytest HTML report
test-results/              # Generic test results directory
test-output/               # Generic test output directory
junit.xml                  # JUnit XML test results (used by many CI systems)
report.xml                 # Generic XML test report
*.test                     # Compiled Go test binary


# =============================================================================
# SECTION 6 — ENVIRONMENT & SECRETS
# THE MOST CRITICAL SECTION. These files often contain API keys, database
# passwords, OAuth secrets, and private keys. Committing them — even briefly —
# can permanently expose credentials via Git history and leak to public repos.
# =============================================================================

.env                       # Shell environment variables — almost always contains secrets
.env.*                     # All .env variants (.env.local, .env.production, .env.test …)
!.env.example              # Exception: commit the template file with placeholder values
!.env.sample               # Exception: commit the sample/template file
!.env.template             # Exception: commit the template file
.envrc                     # direnv environment file — may contain secrets
secrets.yml                # Rails / generic secrets file
secrets.json               # Generic secrets JSON
secrets.toml               # Generic secrets TOML
credentials.json           # Generic credentials (e.g., Google service account key)
credentials.yml.enc        # Rails encrypted credentials (the key file is the secret)
config/master.key          # Rails master encryption key — NEVER commit this
config/credentials/*.key   # Rails per-environment encryption keys
*.pem                      # PEM-encoded certificate or private key
*.key                      # Generic private key file
*.p12                      # PKCS#12 certificate + private key bundle
*.pfx                      # PFX certificate bundle (Windows name for PKCS#12)
*.cer                      # DER/PEM certificate (less likely to have private key but still)
*.der                      # DER-encoded certificate
*.crt                      # Certificate file
*.keystore                 # Java keystore (contains private keys)
*.jks                      # Java KeyStore (alternate extension)
serviceAccountKey.json     # Google Cloud / Firebase service account key
google-services.json       # Google Services config (contains API keys for Android)
GoogleService-Info.plist   # Google Services config (contains API keys for iOS)
*.tfstate                  # Terraform state — contains all resource attributes (often secrets)
*.tfstate.*                # Terraform state backups and plan files
.terraform/                # Terraform plugin cache and credentials
terraform.tfvars           # Terraform variable definitions — often contains secrets
*.tfvars                   # Any Terraform vars file — review before committing
.vault_pass                # Ansible Vault password file
vault_password_file        # Ansible Vault password file (alternate name)
.htpasswd                  # Apache HTTP basic-auth password file
.netrc                     # FTP/HTTP credentials file used by many Unix tools
.npmrc                     # npm config — may contain auth tokens (//registry.npmjs.org/:_authToken)
.pypirc                    # PyPI upload credentials
*.asc                      # ASCII-armored GPG key or signed file
id_rsa                     # SSH private key (RSA)
id_dsa                     # SSH private key (DSA)
id_ecdsa                   # SSH private key (ECDSA)
id_ed25519                 # SSH private key (Ed25519)


# =============================================================================
# SECTION 7 — LOGS & DATABASES
# Logs grow unboundedly and are rotated by infrastructure — not version control.
# SQLite/local databases contain runtime state, not schema (use migrations).
# =============================================================================

*.log                      # Any log file — runtime output, not source
logs/                      # Log directory
*.log.*                    # Rotated log files (e.g., app.log.1, app.log.2)
npm-debug.log              # npm debug log
yarn-debug.log             # Yarn debug log
yarn-error.log             # Yarn error log
lerna-debug.log            # Lerna monorepo debug log
pip-log.txt                # pip install log
pip-delete-this-directory.txt  # pip cleanup marker
*.sql.gz                   # Compressed database dump (large, not source)
*.sqlite                   # SQLite database file — runtime state, not schema
*.sqlite3                  # SQLite3 database file
*.db                       # Generic database file
*.db-shm                   # SQLite shared memory file (WAL mode)
*.db-wal                   # SQLite write-ahead log (WAL mode)
db.sqlite3                 # Django default SQLite database
db.sqlite3-journal         # Django/SQLite journal file


# =============================================================================
# SECTION 8 — PACKAGE & DISTRIBUTION ARCHIVES
# Built distribution files belong in a package registry (npm, PyPI, RubyGems),
# not in source control. They're large, binary, and always regenerable.
# =============================================================================

*.tar.gz                   # Gzip-compressed tape archive (distribution tarball)
*.tgz                      # Alternate extension for .tar.gz
*.tar.bz2                  # Bzip2-compressed archive
*.tar.xz                   # XZ-compressed archive
*.zip                      # ZIP archive (build/release artifact)
*.7z                       # 7-Zip archive
*.rar                      # RAR archive
*.deb                      # Debian/Ubuntu package (build artifact)
*.rpm                      # Red Hat/Fedora package (build artifact)
*.snap                     # Snapcraft package (build artifact)
*.dmg                      # macOS disk image (build artifact)
*.pkg                      # macOS / Windows package (build artifact)
*.whl                      # Python wheel distribution package
*.egg                      # Python egg distribution package


# =============================================================================
# SECTION 9 — DOCUMENTATION GENERATORS
# Auto-generated API docs are rebuilt from source code comments by CI and
# published to a hosting site — they don't belong in the source repo.
# =============================================================================

site/                      # MkDocs static site output
docs/_build/               # Sphinx built documentation
docs/api/                  # Generated API reference docs (doxygen, pdoc, etc.)
_site/                     # Jekyll static site output (for non-GitHub-Pages repos)
.docusaurus/               # Docusaurus cache and build
.cache-loader/             # Docusaurus webpack cache
javadoc/                   # Generated Javadoc HTML
rdoc/                      # Generated Ruby RDoc output
*.dox                      # Doxygen config backup / intermediate


# =============================================================================
# SECTION 10 — CLOUD, INFRASTRUCTURE & DEVOPS
# Infrastructure-as-code tools store downloaded provider plugins and cached
# state locally — these are large, machine-specific, and should never be shared.
# =============================================================================

# --- Terraform ---
.terraform/                # Downloaded providers and modules — restored via `terraform init`
.terraform.lock.hcl        # Note: COMMIT this — it pins provider versions
*.tfstate                  # Terraform state (duplicated from secrets section for emphasis)
*.tfstate.backup           # Terraform state backup
crash.log                  # Terraform crash log
crash.*.log                # Terraform crash log (versioned)
override.tf                # Terraform local override file (not for sharing)
override.tf.json           # Terraform local override (JSON)
*_override.tf              # Terraform override file pattern
*_override.tf.json         # Terraform override file pattern (JSON)

# --- Ansible ---
*.retry                    # Ansible failed-hosts retry file (created when a playbook partially fails)
.vault_pass                # Vault password file (duplicated for emphasis)

# --- Docker ---
.docker/                   # Docker local context / config directory
docker-compose.override.yml  # Local Docker Compose override — machine-specific service tweaks

# --- Kubernetes ---
kubeconfig                 # Kubernetes config with cluster credentials
*.kubeconfig               # Kubernetes config variant

# --- Serverless Framework ---
.serverless/               # Serverless Framework deployment package and cache

# --- AWS SAM ---
.aws-sam/                  # AWS SAM CLI build artifacts

# --- Vagrant ---
.vagrant/                  # Vagrant VM metadata and state (machine-specific)


# =============================================================================
# SECTION 11 — LINTERS & FORMATTERS (CACHE FILES)
# Linters store caches to avoid re-checking unchanged files. These caches are
# machine-specific and should be regenerated, not shared.
# =============================================================================

.eslintcache               # ESLint lint result cache (JavaScript)
.stylelintcache            # Stylelint result cache (CSS)
.prettiercache             # Prettier format cache
.ruff_cache/               # Ruff Python linter cache
.flake8                    # flake8 config (ignore if auto-generated; commit if hand-authored)
.rubocop-*                 # RuboCop result cache
.golangci-lint/            # golangci-lint cache
.scalafmt.conf.bak         # Scalafmt backup config


# =============================================================================
# SECTION 12 — MISC DEVELOPMENT TOOLS
# =============================================================================

# --- Jupyter Notebooks ---
.ipynb_checkpoints/        # Jupyter auto-save checkpoints — contain stale cell outputs

# --- Python Interactive ---
profile_default/           # IPython default profile
ipython_config.py          # IPython configuration

# --- Profiling ---
*.prof                     # Python / Go / generic profiling output
*.pstats                   # Python cProfile stats file
*.cpuprofile               # Node.js/V8 CPU profile
*.heapsnapshot             # Node.js V8 heap snapshot (can be hundreds of MB)

# --- Mock data / fixtures generated at runtime ---
__mocks__/generated/       # Auto-generated mock data (not hand-authored fixtures)

# --- Storybook ---
storybook-static/          # Storybook built static site output

# --- Chromatic / Percy ---
.chromatic/                # Chromatic visual testing cache

# --- Nx monorepo ---
.nx/cache/                 # Nx computation cache
.nx/workspace-data/        # Nx workspace analysis data

# --- Turborepo ---
.turbo/                    # Turborepo build cache

# --- Rush monorepo ---
common/deploy/             # Rush deploy staging directory
common/temp/               # Rush temporary files

# --- next.js ---
.next/                     # Next.js build output and cache
out/                       # Next.js static export output

# --- Nuxt.js ---
.nuxt/                     # Nuxt.js build output and cache
.output/                   # Nuxt 3 output directory

# --- Gatsby ---
.cache/                    # Gatsby cache directory
public/                    # Gatsby static build output (if not serving from /public)

# --- SvelteKit ---
.svelte-kit/               # SvelteKit generated types and build output

# --- Remix ---
build/                     # Remix server build output
public/build/              # Remix client build output

# --- Astro ---
dist/                      # Astro build output
.astro/                    # Astro cache and generated types

# --- Expo (React Native) ---
.expo/                     # Expo local state and project ID cache
.expo-shared/              # Expo shared asset cache


# =============================================================================
# END OF MASTER .GITIGNORE
# =============================================================================
# Tips:
#   • Run `git check-ignore -v <file>` to find which rule is ignoring a file.
#   • Use `git rm --cached <file>` to untrack a file already committed.
#   • Add project-specific ignores below, or in a .gitignore inside that folder.
#   • Team-specific ignores (editor, OS) belong in ~/.gitignore_global, not here.
# =============================================================================
