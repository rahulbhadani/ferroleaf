# =============================================================================
# MASTER .GITIGNORE — All Major Programming Languages & Environments
# =============================================================================
# Why use .gitignore?
#   Git tracks every file in your project unless told otherwise. Many tools
#   generate files that are machine-specific, auto-rebuilt, contain secrets,
#   or are simply too large/noisy for version control. Committing these causes
#   merge conflicts, bloated repos, security leaks, and broken cross-platform
#   builds. This file tells Git to silently ignore them.
# =============================================================================


# =============================================================================
# SECTION 1 — OPERATING SYSTEM FILES
# Generated automatically by macOS, Windows, and Linux. They encode local
# display preferences and file metadata that differ per machine — committing
# them causes noisy diffs and conflicts for every collaborator.
# =============================================================================

# --- macOS ---
.DS_Store                  # Finder folder-view settings (icon positions, sort order)
.DS_Store?                 # Variant created on network drives
._*                        # Resource fork / extended-attribute sidecar files
.Spotlight-V100            # Spotlight search index for a volume
.Trashes                   # macOS Trash metadata on external volumes
.AppleDouble               # AppleDouble-format resource forks
.LSOverride                # Launch Services override database
Icon                       # Custom folder icon file (has a hidden carriage return in the name)
.AppleDB                   # Apple desktop database
.AppleDesktop              # Apple desktop metadata

# --- Windows ---
Thumbs.db                  # Explorer thumbnail cache — per-machine, not project data
Thumbs.db:encryptable      # Encrypted variant of thumbnail cache
ehthumbs.db                # Windows Media Center thumbnail cache
ehthumbs_vista.db          # Vista-era thumbnail cache
Desktop.ini                # Folder customisation settings (layout, icon, tooltip)
$RECYCLE.BIN/              # Windows Recycle Bin metadata folder
*.cab                      # Windows Cabinet compressed archive (build artifact)
*.msi                      # Windows Installer package (build artifact)
*.msm                      # Windows Installer merge module
*.msp                      # Windows Installer patch
*.lnk                      # Windows shortcut — machine-specific absolute paths inside
[Dd]esktop.ini             # Case-insensitive match for Desktop.ini
*.stackdump                # Cygwin crash dump

# --- Linux ---
*~                         # Backup files created by many Linux text editors (nano, gedit)
.fuse_hidden*              # Temporary files created by FUSE mounts
.directory                 # KDE Dolphin folder metadata
.Trash-*                   # Per-user trash directories on Linux filesystems
.nfs*                      # Stale NFS lock files left after a crash


# =============================================================================
# SECTION 2 — EDITORS & IDEs
# Each editor stores its own project config, workspace state, and plugin data
# locally. These are personal preferences — forcing them on collaborators breaks
# their setup and creates pointless conflicts.
# =============================================================================

# --- Visual Studio Code ---
.vscode/                   # Workspace settings, launch configs, extension recommendations
!.vscode/settings.json     # Exception: shared formatter/linting rules are useful to commit
!.vscode/extensions.json   # Exception: recommended extensions list can be shared
!.vscode/launch.json       # Exception: shared debug launch configs
.history/                  # Local History extension — per-machine edit history
*.vsix                     # VS Code extension package (binary build artifact)

# --- JetBrains IDEs (IntelliJ, PyCharm, WebStorm, GoLand, Rider …) ---
.idea/                     # Entire IDE project directory (workspace, run configs, indexes)
!.idea/codeStyles/         # Exception: shared code style settings
!.idea/inspectionProfiles/ # Exception: shared inspection (lint) profiles
*.iws                      # IntelliJ workspace file — machine-specific open tabs / layout
*.iml                      # IntelliJ module file — auto-regenerated from build tool
*.ipr                      # IntelliJ project file (old format, replaced by .idea/)
out/                       # IntelliJ default compiled-output directory
cmake-build-*/             # CLion CMake build directories

# --- Eclipse ---
.project                   # Eclipse project descriptor — contains machine-specific paths
.classpath                 # Eclipse Java classpath — rebuilt by Maven/Gradle
.settings/                 # Eclipse per-project settings (formatter, compiler)
.loadpath                  # Eclipse PHP project loadpath
.buildpath                 # Eclipse PHP build path
bin/                       # Eclipse default Java bytecode output folder

# --- NetBeans ---
nbproject/private/         # NetBeans private project files (machine-specific)
nbbuild/                   # NetBeans build output
nbdist/                    # NetBeans distribution output
.nb-gradle/                # NetBeans Gradle support cache

# --- Vim / Neovim ---
*.swp                      # Vim swap file — open-file recovery buffer
*.swo                      # Vim secondary swap file
*.swn                      # Vim tertiary swap file
*~                         # Vim backup file (also matches generic Linux backups above)
.netrwhist                 # Vim netrw browsing history
Session.vim                # Vim session file — restores window layout / open files
.vim/                      # Local Vim config directory
tags                       # ctags/cscope tag file — auto-generated code index

# --- Emacs ---
\#*\#                      # Emacs auto-save file (created on crash, deleted on clean exit)
/.emacs.desktop            # Emacs desktop file — saved session state
/.emacs.desktop.lock       # Lock file preventing two Emacs instances from loading session
*.elc                      # Compiled Emacs Lisp bytecode
auto-save-list             # Emacs list of auto-save files
tramp                      # Emacs Tramp remote-connection state
.\#*                       # Emacs lock symlinks (created while editing a file)

# --- Sublime Text ---
*.tmlanguage.cache         # Sublime compiled syntax grammar cache
*.tmPreferences.cache      # Sublime compiled preferences cache
*.stTheme.cache            # Sublime compiled theme cache
*.sublime-workspace        # Sublime workspace — open files, pane layout (machine-specific)
*.sublime-project          # Sublime project file (may contain absolute paths)
sftp-config.json           # Sublime SFTP plugin config — may contain credentials!
Package Control.last-run   # Sublime Package Control metadata
Package Control.ca-list    # Package Control CA bundle
Package Control.ca-bundle  # Package Control CA bundle (alternate)
Package Control.system-ca-bundle # System CA bundle reference

# --- Atom ---
.atom/                     # Atom editor settings and packages directory

# --- TextMate ---
*.tmproj                   # TextMate project file
*.tmproject                # TextMate project file (alternate extension)
tmtags                     # TextMate tags file

# --- Notepad++ ---
nppBackup/                 # Notepad++ backup files directory

# --- Xcode ---
*.xcodeproj/xcuserdata/    # Per-developer breakpoints, scheme, and window state
*.xcworkspace/xcuserdata/  # Same, for workspaces
*.xcworkspace/xcshareddata/previews/ # Xcode canvas preview snapshots
*.moved-aside              # Files renamed by Xcode during a framework migration
*.pbxuser                  # Old Xcode per-user project settings
*.mode1v3                  # Xcode 3 window mode file
*.mode2v3                  # Xcode 3 alternate window mode file
*.perspectivev3            # Xcode 3 perspective file
DerivedData/               # Xcode build products and intermediate files (large, auto-rebuilt)
*.hmap                     # Xcode header map (auto-generated C/C++ include index)
*.ipa                      # Compiled iOS application archive (build artifact)
*.xcarchive                # Xcode archive (build artifact, often hundreds of MB)


# =============================================================================
# SECTION 3 — DEPENDENCY DIRECTORIES
# Package managers download and install dependencies on demand from a lockfile.
# Committing these directories bloats the repo (often hundreds of MB), creates
# OS-specific binary conflicts, and gives a false sense of reproducibility.
# =============================================================================

# --- JavaScript / Node.js ---
node_modules/              # npm/yarn/pnpm installed packages — restored via package-lock.json
npm-debug.log*             # npm error log — per-run diagnostics, not project state
yarn-debug.log*            # Yarn debug log
yarn-error.log*            # Yarn error log
.pnpm-debug.log*           # pnpm debug log
.npm/                      # npm cache directory
.yarn/cache                # Yarn Berry (v2+) download cache (commit only if using Zero-Installs)
.yarn/unplugged            # Yarn Berry unpacked native modules
.yarn/build-state.yml      # Yarn Berry build state
.pnp.js                    # Yarn Plug'n'Play loader (commit only if using PnP)
.pnp.cjs                   # Yarn PnP loader (CJS variant)

# --- Python ---
__pycache__/               # Python 3 bytecode cache directory
*.py[cod]                  # Compiled Python bytecode (.pyc, .pyo, .pyd) — machine-specific
*$py.class                 # Jython compiled class file
*.egg                      # Python egg distribution archive
*.egg-info/                # Python egg metadata directory (generated by setuptools)
dist/                      # Python distribution output (sdist, wheel)
build/                     # Python build directory
eggs/                      # Deprecated Python eggs directory
.eggs/                     # Pytest eggs cache
.tox/                      # tox virtualenv/test automation directory
.nox/                      # nox virtualenv/automation directory
.venv/                     # Virtual environment (common name)
venv/                      # Virtual environment (alternate common name)
env/                       # Virtual environment (alternate name)
ENV/                       # Virtual environment (alternate name, uppercase)
.Python                    # Virtualenv Python symlink
pip-wheel-metadata/        # pip wheel build metadata
.pytype/                   # pytype static analysis output
.mypy_cache/               # mypy type-checker cache
.pyre/                     # Pyre (Facebook) type-checker cache
.dmypy.json                # mypy daemon state
dmypy.json                 # mypy daemon state (alternate location)
.pybuilder/                # PyBuilder build tool output
target/                    # PyBuilder target directory
Pipfile.lock               # Pipenv lockfile — commit this! (listed here as reminder only)
poetry.lock                # Poetry lockfile — commit this! (listed here as reminder only)
instance/                  # Flask per-instance config and SQLite database folder
.webassets-cache           # Flask-Assets compiled asset cache
celerybeat-schedule        # Celery beat periodic-task schedule state
celerybeat.pid             # Celery beat PID file

# --- Ruby ---
*.gem                      # Compiled Ruby gem archive (build artifact)
*.rbc                      # Rubinius compiled bytecode
/.bundle/                  # Bundler local plugin config
/vendor/bundle             # Bundler installed gems (restored via `bundle install`)
Gemfile.lock               # Note: COMMIT this for applications, ignore for libraries
.bundle/config             # Bundler local machine config (may contain credentials)
.rubocop-*                 # RuboCop generated cache/result files

# --- Java / JVM ---
*.class                    # Java compiled bytecode — always rebuilt from source
*.jar                      # Java archive (build artifact — unless it's a library you ship)
*.war                      # Java web application archive (build artifact)
*.ear                      # Java enterprise application archive (build artifact)
*.nar                      # Apache NiFi archive
hs_err_pid*                # JVM crash dump — diagnostic only
replay_pid*                # JVM replay compilation log
.gradle/                   # Gradle per-project cache and daemon files
gradle-app.setting         # Gradle App plugin settings
.gradletasknamecache       # Gradle task name cache
!gradle/wrapper/gradle-wrapper.jar  # Exception: Gradle wrapper JAR should be committed
build/                     # Gradle/Maven default build output directory
out/                       # IntelliJ/Gradle alternate build output
target/                    # Maven default build output directory
pom.xml.tag                # Maven release plugin backup
pom.xml.releaseBackup      # Maven release plugin backup
pom.xml.versionsBackup     # Maven versions plugin backup
pom.xml.next               # Maven release plugin next version
release.properties         # Maven release plugin properties
dependency-reduced-pom.xml # Maven Shade plugin generated POM
buildNumber.properties     # Maven build number plugin output
.mvn/timing.properties     # Maven internal build timing
.mvn/wrapper/maven-wrapper.jar  # Note: COMMIT this if using Maven wrapper

