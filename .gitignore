# =============================================================================
# SECTION 4 — BUILD TOOLS & TASK RUNNERS
# Build outputs are always regenerated — committing them causes multi-MB diffs
# on trivial code changes and prevents reproducible builds from source.
# =============================================================================

# webpack persistent cache (speeds up rebuilds, not project data)
.cache/
# webpack/Vite/Rollup bundle output — rebuilt on deploy
dist/
# Parcel bundler cache
.parcel-cache/
# Vite dev server cache
.vite/
# Rollup build cache
.rollup.cache/
# Grunt plugin cache
.grunt/
# Sass/SCSS compiled cache (used by many task runners)
.sass-cache/
# Bower installed front-end packages (deprecated, use npm)
bower_components/
# Bazel symlinked output directories (bazel-bin, bazel-out, etc.)
bazel-*
/bazel-out
# Buck build output directory
buck-out/
# GCC auto-generated dependency files for incremental builds
*.d


# =============================================================================
# SECTION 5 — TEST & COVERAGE OUTPUTS
# Test results and coverage reports are generated by CI — committing them makes
# the repo reflect the last local run rather than the canonical CI state.
# =============================================================================

# Code coverage report directory (JavaScript/generic)
coverage/
# LCOV coverage data file
*.lcov
# Istanbul/nyc raw coverage data (JavaScript)
.nyc_output/
# Python coverage.py HTML report
htmlcov/
# Python coverage.py binary data file
.coverage
.coverage.*
# Python/generic XML coverage report (e.g., for Codecov)
coverage.xml
# Nose test results XML
nosetests.xml
# Pytest HTML report
pytest-report.html
# Generic test results directories
test-results/
test-output/
# JUnit XML test results (used by many CI systems)
junit.xml
report.xml
# Compiled Go test binary
*.test


# =============================================================================
# SECTION 6 — ENVIRONMENT & SECRETS
# THE MOST CRITICAL SECTION. These files often contain API keys, database
# passwords, OAuth secrets, and private keys. Committing them — even briefly —
# can permanently expose credentials via Git history and leak to public repos.
# =============================================================================

# Shell environment variables — almost always contains secrets
.env
# All .env variants (.env.local, .env.production, .env.test)
.env.*
# Exception: commit the template file with placeholder values
!.env.example
!.env.sample
!.env.template
# direnv environment file — may contain secrets
.envrc
# Rails / generic secrets file
secrets.yml
secrets.json
secrets.toml
# Generic credentials (e.g., Google service account key)
credentials.json
# Rails master encryption key — NEVER commit this
config/master.key
# Rails per-environment encryption keys
config/credentials/*.key
# PEM-encoded certificate or private key
*.pem
# Generic private key file
*.key
# PKCS#12 certificate + private key bundle
*.p12
*.pfx
# Certificate files
*.cer
*.der
*.crt
# Java keystore (contains private keys)
*.keystore
*.jks
# Google Cloud / Firebase service account key
serviceAccountKey.json
# Google Services config (contains API keys for Android)
google-services.json
# Google Services config (contains API keys for iOS)
GoogleService-Info.plist
# Terraform state — contains all resource attributes (often secrets)
*.tfstate
*.tfstate.*
# Terraform plugin cache and credentials
.terraform/
# Terraform variable definitions — often contains secrets
terraform.tfvars
*.tfvars
# Ansible Vault password file
.vault_pass
vault_password_file
# Apache HTTP basic-auth password file
.htpasswd
# FTP/HTTP credentials file used by many Unix tools
.netrc
# npm config — may contain auth tokens
.npmrc
# PyPI upload credentials
.pypirc
# SSH private keys
id_rsa
id_dsa
id_ecdsa
id_ed25519


# =============================================================================
# SECTION 7 — LOGS & DATABASES
# Logs grow unboundedly and are rotated by infrastructure — not version control.
# SQLite/local databases contain runtime state, not schema (use migrations).
# =============================================================================

# Any log file — runtime output, not source
*.log
# Log directory
logs/
# Rotated log files (e.g., app.log.1, app.log.2)
*.log.*
# Common named log files
npm-debug.log
yarn-debug.log
yarn-error.log
lerna-debug.log
pip-log.txt
pip-delete-this-directory.txt
# Compressed database dump (large, not source)
*.sql.gz
# SQLite database files — runtime state, not schema
*.sqlite
*.sqlite3
*.db
# SQLite shared memory / WAL files
*.db-shm
*.db-wal
# Django default SQLite database
db.sqlite3
db.sqlite3-journal


# =============================================================================
# SECTION 8 — PACKAGE & DISTRIBUTION ARCHIVES
# Built distribution files belong in a package registry (npm, PyPI, RubyGems),
# not in source control. They're large, binary, and always regenerable.
# =============================================================================

# Compressed archives (distribution tarballs)
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
# ZIP archive (build/release artifact)
*.zip
# 7-Zip archive
*.7z
# RAR archive
*.rar
# Linux packages (build artifacts)
*.deb
*.rpm
*.snap
# macOS disk image (build artifact)
*.dmg
# macOS / Windows package (build artifact)
*.pkg
# Python distribution packages
*.whl
*.egg


# =============================================================================
# SECTION 9 — DOCUMENTATION GENERATORS
# Auto-generated API docs are rebuilt from source code comments by CI and
