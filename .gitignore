build/
# Deprecated Python eggs directory
eggs/
.eggs/
# tox virtualenv/test automation directory
.tox/
# nox virtualenv/automation directory
.nox/
# Virtual environment (common names)
.venv/
venv/
env/
ENV/
# Virtualenv Python symlink
.Python
# pip wheel build metadata
pip-wheel-metadata/
# pytype static analysis output
.pytype/
# mypy type-checker cache
.mypy_cache/
# Pyre (Facebook) type-checker cache
.pyre/
# mypy daemon state
.dmypy.json
dmypy.json
# PyBuilder build tool output
.pybuilder/
# Flask per-instance config and SQLite database folder
instance/
# Flask-Assets compiled asset cache
.webassets-cache
# Celery beat periodic-task schedule state
celerybeat-schedule
# Celery beat PID file
celerybeat.pid

